rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isBackendService() {
      return request.auth != null && request.auth.token.email == 'backend-service@zenitsmm.com';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isBackendService() || isOwner(userId);
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read: if isSignedIn() || isBackendService();
      allow write: if isBackendService();
    }

    // Services collection
    match /services/{serviceId} {
      allow read: if isSignedIn() || isBackendService();
      allow write: if isBackendService();
    }

    // Orders collection
    match /orders/{orderId} {
      allow read: if isBackendService() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isBackendService() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if isBackendService() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isBackendService() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
    }

    // Tickets collection
    match /tickets/{ticketId} {
      allow read: if isBackendService() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isBackendService() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
    }

    // Providers collection
    match /providers/{providerId} {
      allow read, write: if isBackendService();
    }

    // Settings collection
    match /settings/{settingsId} {
      allow read: if isSignedIn() || isBackendService();
      allow write: if isBackendService();
    }

    // Logs collection
    match /logs/{logId} {
      allow read, write: if isBackendService();
    }

    // Audit logs collection
    match /audit_logs/{logId} {
      allow read, write: if isBackendService();
    }

    // Security logs collection
    match /security_logs/{logId} {
      allow read, write: if isBackendService();
    }

    // Notifications collection
    match /notifications/{notifId} {
      allow read: if isBackendService() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == null));
      allow write: if isBackendService();
    }

    // Wallets collection
    match /wallets/{userId} {
      allow read, write: if isBackendService() || isOwner(userId);
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if isBackendService() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isBackendService() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
    }
  }
}
